#!/usr/bin/env bash
set -euo pipefail

sources_list=/etc/apt/sources.list.d/ubuntu.sources
if [ -f "$sources_list" ] && grep -q 'http://archive\.ubuntu\.com/ubuntu/' "$sources_list"; then
  sudo sed -i.bak 's|http://archive\.ubuntu\.com/ubuntu/|https://ftp.udx.icscoe.jp/Linux/ubuntu/|g' "$sources_list"
fi

sudo apt update
sudo apt install -y git build-essential

if ! command -v brew > /dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
